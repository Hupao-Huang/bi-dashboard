# ============================================================
# BI 看板敏感凭证环境变量模板 (生产环境推荐用法)
# ============================================================
# 用法:
#   1. 复制为 .env 并填入真实值 (.env 已 .gitignore)
#   2. 启动 bi-server 前先 source .env (Linux) 或在 Windows
#      schtasks 任务里把 BI_* 设成"环境变量"
#   3. config.json 留空对应字段 (或保留默认值), 启动时被环境变量覆盖
#
# 优先级: 环境变量 > config.json
# 命名规则: BI_<SECTION>_<FIELD>
# ============================================================

# ---------- MySQL ----------
BI_DB_HOST=127.0.0.1
BI_DB_USER=root
BI_DB_PASSWORD=改我
BI_DB_NAME=bi_dashboard

# ---------- 吉客云 ERP (主 AppKey, 销售单走 trade) ----------
BI_JACKYUN_APPKEY=
BI_JACKYUN_SECRET=
BI_JACKYUN_TRADE_APPKEY=
BI_JACKYUN_TRADE_SECRET=

# ---------- 钉钉 OAuth + Webhook ----------
BI_DINGTALK_WEBHOOK_TOKEN=
BI_DINGTALK_WEBHOOK_SECRET=
BI_DINGTALK_CLIENT_ID=
BI_DINGTALK_CLIENT_SECRET=
BI_DINGTALK_NOTIFY_APP_KEY=
BI_DINGTALK_NOTIFY_APP_SECRET=

# ---------- 合思费控 ----------
BI_HESI_APPKEY=
BI_HESI_SECRET=

# ---------- YS 用友 YonBIP ----------
BI_YONSUITE_APPKEY=
BI_YONSUITE_APPSECRET=

# ---------- Webhook (sync-ops/clear-cache 接口校验) ----------
BI_WEBHOOK_SECRET=

# ---------- Sentry 错误监控 (空时 SDK 静默禁用, 不影响功能) ----------
# 注册账号: https://sentry.io (免费 plan 5K event/月够用)
# 创建 Go 项目后, 把 DSN 粘到这里
SENTRY_DSN=
SENTRY_ENV=production
# SENTRY_RELEASE=v1.47.48  # 可选, 让 Sentry 把错误归到具体版本
